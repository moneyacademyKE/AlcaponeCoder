{:paths ["clj_agents" "tests"]
 :tasks
 {agent-loop {:doc "Run s01 Agent Loop"
              :task (shell "bb clj_agents/s01_agent_loop.clj")}
  test {:doc "Run tests"
        :task (do (require '[clojure.test :as t] 'registry-test 'agent-test 'agent-error-test)
                 (let [res (clojure.test/run-tests 'registry-test 'agent-test 'agent-error-test)]
                   (when (pos? (+ (:fail res) (:error res)))
                     (System/exit 1))))}}}
